# Dependency directories (monorepo paths)
**/node_modules/

# Local Environment Secret files (Keep database passwords and secret keys safe)
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Backend specific runtime assets & local SQLite databases
**/uploads/
**/dev.sqlite

# Vite / React Admin build outputs
**/dist/

# Expo / React Native build and cache outputs
**/.expo/
**/web-build/
**/expo-env.d.ts
**/.metro-health-check*

# Android / iOS native build outputs
edunotify-mobile-app/ios/
edunotify-mobile-app/android/
.kotlin/

# Keys, credentials and certificates
*.jks
*.p8
*.p12
*.key
*.pem
*.mobileprovision

# Debug logs
npm-debug.*
yarn-debug.*
yarn-error.*
pnpm-debug.log*

# OS-specific files
.DS_Store
Thumbs.db

# Firebase Service Account Credentials
**/firebase-service-account.json

